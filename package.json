{
  "name": "vedanshi-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "validate": "python scripts/validate_projects.py --mode production",
    "watch:projects": "node scripts/watch.js",
    "predev": "npm run validate",
    "dev": "run-p dev:vite watch:projects",
    "dev:vite": "vite",
    "prebuild": "npm run validate",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.3",
    "chokidar": "^5.0.0",
    "coi-serviceworker": "^0.1.7",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
